{
  "name": "vscode-objectscript-search",
  "displayName": "ObjectScript Search",
  "description": "Server-side search for InterSystems IRIS ObjectScript code",
  "version": "0.1.3",
  "publisher": "grongierisc",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/grongierisc/vscode-objectscript-search"
  },
  "engines": {
    "vscode": "^1.75.0"
  },
  "icon": "media/icon.png",
  "categories": [
    "Other"
  ],
  "keywords": [
    "intersystems",
    "objectscript",
    "iris",
    "search"
  ],
  "extensionDependencies": [
    "intersystems-community.servermanager",
    "intersystems-community.vscode-objectscript"
  ],
  "activationEvents": [],
  "main": "./dist/extension",
  "contributes": {
    "views": {
      "intersystems-community_servermanager": [
        {
          "id": "ObjectScriptSearch",
          "name": "Search",
          "contextualTitle": "ObjectScript Search",
          "icon": "media/search.svg"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "ObjectScriptSearch",
        "contents": "No active ObjectScript connection.\n\nOpen a workspace folder and ensure `objectscript.conn` is configured.\n[Open Workspace Settings](command:workbench.action.openWorkspaceSettings)",
        "when": "!objectscriptSearch.connected"
      },
      {
        "view": "ObjectScriptSearch",
        "contents": "$(search) [Click to search…](command:objectscriptSearch.search)\n\nUse [Options…](command:objectscriptSearch.showOptions) to configure file types and match behaviour.",
        "when": "objectscriptSearch.connected"
      }
    ],
    "commands": [
      {
        "command": "objectscriptSearch.search",
        "title": "Search…",
        "icon": "$(search)",
        "category": "ObjectScript"
      },
      {
        "command": "objectscriptSearch.showOptions",
        "title": "Options…",
        "icon": "$(filter)",
        "category": "ObjectScript"
      },
      {
        "command": "objectscriptSearch.clearResults",
        "title": "Clear Results",
        "icon": "$(clear-all)",
        "category": "ObjectScript"
      },
      {
        "command": "objectscriptSearch.copyResults",
        "title": "Copy Results",
        "icon": "$(copy)",
        "category": "ObjectScript"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "objectscriptSearch.search",
          "when": "view == ObjectScriptSearch && objectscriptSearch.connected",
          "group": "navigation@1"
        },
        {
          "command": "objectscriptSearch.showOptions",
          "when": "view == ObjectScriptSearch",
          "group": "navigation@2"
        },
        {
          "command": "objectscriptSearch.clearResults",
          "when": "view == ObjectScriptSearch",
          "group": "navigation@3"
        },
        {
          "command": "objectscriptSearch.copyResults",
          "when": "view == ObjectScriptSearch",
          "group": "navigation@4"
        }
      ]
    },
    "configuration": {
      "title": "ObjectScript Search",
      "properties": {
        "objectscriptSearch.maxResults": {
          "type": "number",
          "default": 100,
          "minimum": 1,
          "maximum": 1000,
          "description": "Maximum number of search results to return per search."
        },
        "objectscriptSearch.includeSystem": {
          "type": "boolean",
          "default": false,
          "description": "Include system (%-prefixed) classes and routines in search results."
        },
        "objectscriptSearch.allowSelfSignedCertificates": {
          "type": "boolean",
          "default": false,
          "description": "Allow connections to IRIS servers with self-signed SSL/TLS certificates."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "compile-tests": "tsc -p tsconfig.test.json",
    "pretest": "npm run compile-tests",
    "test": "node ./out/test/runTest.js",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.0.0",
    "@types/sinon": "^21.0.0",
    "@types/vscode": "^1.75.0",
    "@vscode/test-electron": "^2.5.2",
    "mocha": "^11.7.5",
    "sinon": "^21.0.2",
    "ts-loader": "^9.4.0",
    "typescript": "^5.0.0",
    "webpack": "^5.80.0",
    "webpack-cli": "^5.0.0"
  },
  "dependencies": {
    "@intersystems-community/intersystems-servermanager": "^3.10.2"
  }
}
